{
  "name": "fc-squad-ai",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node --import tsx scripts/seed-db.ts && node --import tsx scripts/export-data.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "node --import tsx scripts/seed-db.ts",
    "seed:force": "node --import tsx scripts/seed-db.ts --force",
    "seed:reset": "node --import tsx scripts/seed-db.ts --reset",
    "seed:stats": "node --import tsx scripts/seed-db.ts --stats",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "deploy": "bash scripts/deploy.sh"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@vercel/blob": "^2.3.2",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
