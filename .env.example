# ---------------------------------------------------------------------------
# FC Squad AI — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in the values.
# On Vercel, set these in Project Settings → Environment Variables.
# ---------------------------------------------------------------------------

# --- AI (Gemini API) ---
# Required for AI-powered squad parsing. Falls back to rule-based parser if missing.
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_KEY=
# Alternative key name (checked if GOOGLE_GENERATIVE_AI_KEY is empty):
# GEMINI_API_KEY=

# --- Nexon FC Online Open API ---
# Used for player metadata enrichment (spid, seasonid, spposition).
# App registration: https://developers.nexon.com/
NEXON_API_KEY=
NEXON_APP_ID=258842

# --- Price Crawl System ---
# Auth token for manual crawl triggers via POST /api/crawl.
# If not set, manual triggers are disabled in production (cron still works).
# CRAWL_AUTH_TOKEN=
